  "keyFeatures": [
    "Hosted payment page generation — redirect customers to a Taliup-hosted checkout URL",
    "Webhook signature verification with HMAC-SHA256",
    "Structured error handling via ApiException",
    "Support for CAD and USD currencies",
    "Optional line-item details, customer info, and session expiry",
    "Transaction verification endpoint"
